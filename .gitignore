# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/

# Environment variables (CRITICAL: Do not leak these!)
.env
.env.local
.env.*.local

# Database / Drizzle
# If you use a local sqlite file in the db folder, ignore it:
*.db
*.sqlite
# Optional: if you want to keep migrations but ignore local data
# db/data/

# Docker
.dockerignore
# Note: Usually we keep Dockerfile and docker-compose.yml in git, 
# but ignore local data volumes if you create them.

# Editor / System files
.DS_Store
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
tsconfig.tsbuildinfo

# Node Version Manager
# Some prefer to keep .nvmrc in git to sync node versions, 
# but if you want it private, uncomment the line below:
# .nvmrc
